{
  "compilerOptions": {
    /* Target & Environment */
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "types": ["node"],

    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",
    "sourceMap": true,

    /* Strictness */
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    
    /* Modules */
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}