# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# RAG Model Configuration (FastAPI + Google Gemini)
# The RAG service runs as a separate FastAPI application
# Default port for FastAPI is 8000
# Endpoint: POST /epson/v1/ai-chatbot
RAG_API_URL=http://localhost:8000
RAG_API_ENDPOINT=/epson/v1/ai-chatbot
